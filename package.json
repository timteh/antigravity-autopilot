{
  "name": "antigravity-autopilot-os",
  "displayName": "Antigravity Autopilot â€” OS Level",
  "description": "Auto-accept agent steps in Antigravity IDE â€” no CDP required. Uses OS-level accessibility to click Run/Accept/Continue buttons invisibly.",
  "version": "1.1.0",
  "publisher": "timteh",
  "author": {
    "name": "Tim Melnik",
    "url": "https://github.com/timteh"
  },
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/timteh/antigravity-autopilot"
  },
  "bugs": {
    "url": "https://github.com/timteh/antigravity-autopilot/issues"
  },
  "homepage": "https://github.com/timteh/antigravity-autopilot#readme",
  "sponsor": {
    "url": "https://buymeacoffee.com/timteh"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": [
    "antigravity",
    "auto-accept",
    "autopilot",
    "agent",
    "automation",
    "cursor",
    "windsurf",
    "ai-coding",
    "yolo-mode"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-autopilot.start",
        "title": "Antigravity Autopilot: Start"
      },
      {
        "command": "antigravity-autopilot.stop",
        "title": "Antigravity Autopilot: Stop"
      },
      {
        "command": "antigravity-autopilot.toggle",
        "title": "Antigravity Autopilot: Toggle"
      },
      {
        "command": "antigravity-autopilot.status",
        "title": "Antigravity Autopilot: Show Status"
      }
    ],
    "keybindings": [
      {
        "command": "antigravity-autopilot.toggle",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Antigravity Autopilot",
      "properties": {
        "antigravityAutopilot.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Autopilot"
        },
        "antigravityAutopilot.pollIntervalMs": {
          "type": "number",
          "default": 800,
          "description": "How often (ms) to scan for buttons"
        },
        "antigravityAutopilot.cooldownSeconds": {
          "type": "number",
          "default": 10,
          "description": "Seconds to wait before re-clicking the same button"
        },
        "antigravityAutopilot.scrollCooldownSeconds": {
          "type": "number",
          "default": 3,
          "description": "Seconds between auto-scroll clicks"
        },
        "antigravityAutopilot.autoScroll": {
          "type": "boolean",
          "default": true,
          "description": "Automatically click 'Scroll to bottom' to follow chat"
        },
        "antigravityAutopilot.acceptPatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "^Run",
            "^Accept",
            "^Accept All$",
            "^Send all",
            "^Always Allow",
            "^Always run",
            "^Allow$",
            "^Allow this conversation$",
            "^Continue$",
            "^Keep All$",
            "^Yes$",
            "^Retry$"
          ],
          "description": "Regex patterns for buttons to auto-click"
        },
        "antigravityAutopilot.rejectPatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "^Reject",
            "^Cancel$",
            "^Deny",
            "^Delete",
            "^Remove",
            "^Discard",
            "^Close",
            "^Minimize$",
            "^Maximize$",
            "^Ask every",
            "^Review Changes$"
          ],
          "description": "Regex patterns for buttons to NEVER click"
        }
      }
    }
  }
}
